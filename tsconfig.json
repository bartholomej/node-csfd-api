{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],

    "module": "Preserve",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    "strict": true,
    "strictNullChecks": false, // will be more strict in future releases
    "noImplicitReturns": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["dist", "**/tests/**"]
}